# Green Earth API — environment variable reference
# Copy to .env and fill in values for local development.

# ── Elasticsearch ──────────────────────────────────────────────────────────────
GE_ELASTICSEARCH_URL=https://localhost:9200
GE_ELASTICSEARCH_API_KEY=your-api-key-here
GE_ELASTICSEARCH_VERIFY_SSL=false

# ── Firestore ──────────────────────────────────────────────────────────────────
# GE_FIRESTORE_PROJECT=your-gcp-project
# GE_FIRESTORE_DATABASE=(default)
# GE_FIRESTORE_EMULATOR_HOST=localhost:8080   # set to use the local emulator

# ── AT Protocol / Bluesky ──────────────────────────────────────────────────────
GE_FEED_GENERATOR_DID=did:web:localhost

# ── Auth ───────────────────────────────────────────────────────────────────────
GE_API_KEY=your-api-key-here

# ── GCP Metrics (OpenTelemetry → Cloud Monitoring) ────────────────────────────
# When GE_GCP_PROJECT_ID is empty, metrics are printed to stdout (local dev).
# Set it to your GCP project ID to export to Cloud Monitoring.
GE_GCP_PROJECT_ID=
GE_GCP_REGION=us-central1
GE_SERVICE_NAME=greenearth-api
GE_METRICS_EXPORT_INTERVAL_SEC=60

# ── Observability (optional) ───────────────────────────────────────────────────
# GE_TIMING_LOGS=1   # emit timing log lines for every timed() block
# GE_PROFILE=1       # write per-request pyinstrument flame charts to ./profiles/
# GE_LOG_LEVEL=INFO
