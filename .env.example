########## Common Variables ##########

# Environment
export ENVIRONMENT=local

# Elasticsearch Configuration
export GE_ELASTICSEARCH_URL="https://localhost:9200"
export GE_ELASTICSEARCH_API_KEY="your-elasticsearch-api-key-here"

# GCP Configuration
export PROJECT_ID=my-gcp-project-id
export REGION=us-east1

########## Deployment Variables ########

export API_INSTANCES_MIN=1
export API_INSTANCES_MAX=10

########## Fast API Variables ##########

export API_KEY="your-fast-api-client-key-here"

########## Feed Publishing Variables ##########

# DID of the feed generator service (used by scripts/publish_feed.py)
# e.g. did:web:your-subdomain.ngrok.dev  or  did:web:your-domain.example.com
export GE_FEED_GENERATOR_DID="did:web:your-subdomain.ngrok.dev"

# Bluesky app password for the account that publishes the feed records
export GE_BSKY_APP_PASSWORD="xxxx-xxxx-xxxx-xxxx"

########## Firestore Variables ##########

# To use the Firestore emulator for local development, set this to the
# emulator's host:port (e.g. 127.0.0.1:8080). Leave unset for production.
export GE_FIRESTORE_EMULATOR_HOST="127.0.0.1:8080"

# Firestore project ID. For local emulator with default firebase-tools setup,
# use demo-no-project so writes appear in the same emulator namespace/UI.
export GE_FIRESTORE_PROJECT="demo-no-project"

########## Inference Variables ##########

export GE_INFERENCE_BASE_URL="https://engagement-prediction-inference-url.run.app"
export GE_INFERENCE_API_KEY="inference-service-api-key-here"
export GE_INFERENCE_MAX_HISTORY_LEN=128
